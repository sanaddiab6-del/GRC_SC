# Environment Configuration Example

# Copy this file to .env and update with your actual values
# IMPORTANT: Never commit .env file with real credentials to version control

# ============================================================
# Application Settings
# ============================================================
APP_NAME="SICO GRC Platform"
APP_VERSION="0.1.0-alpha"
ENVIRONMENT="development"  # development, staging, production
DEBUG=true
LOG_LEVEL="INFO"

# ============================================================
# Backend API
# ============================================================
BACKEND_HOST="0.0.0.0"
BACKEND_PORT=8000
API_V1_PREFIX="/api/v1"

# ============================================================
# Frontend
# ============================================================
FRONTEND_HOST="0.0.0.0"
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL="http://localhost:8000"
NEXT_PUBLIC_WS_URL="ws://localhost:8000"

# ============================================================
# Database Configuration
# ============================================================
# PostgreSQL
DATABASE_URL="postgresql://sico_user:your_password@localhost:5432/sico_grc"
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false

# ============================================================
# Redis Cache
# ============================================================
REDIS_URL="redis://localhost:6379/0"
REDIS_PASSWORD=""
REDIS_MAX_CONNECTIONS=50
CACHE_TTL=3600  # seconds

# ============================================================
# Security & Authentication
# ============================================================
SECRET_KEY="your-super-secret-key-change-this-in-production"
JWT_SECRET_KEY="your-jwt-secret-key-change-this"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Requirements
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL=true

# CORS Settings
CORS_ORIGINS="http://localhost:3000,http://localhost:8000"
CORS_ALLOW_CREDENTIALS=true

# ============================================================
# AI/ML Configuration
# ============================================================
# OpenAI
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4"
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=2000

# Embedding Models
EMBEDDING_MODEL_ARABIC="aubmindlab/bert-base-arabertv2"
EMBEDDING_MODEL_ENGLISH="sentence-transformers/all-mpnet-base-v2"
EMBEDDING_MODEL_MULTILINGUAL="sentence-transformers/paraphrase-multilingual-mpnet-base-v2"

# Vector Database
VECTOR_DB_TYPE="chroma"  # chroma or weaviate
VECTOR_DB_PATH="/data/vector_db"
VECTOR_DB_HOST="localhost"
VECTOR_DB_PORT=8080

# RAG Configuration
RAG_TOP_K=5
RAG_CONFIDENCE_THRESHOLD=0.7
RAG_MAX_CONTEXT_LENGTH=4000

# ============================================================
# File Storage
# ============================================================
STORAGE_TYPE="local"  # local, s3, azure
UPLOAD_DIR="/data/uploads"
MAX_UPLOAD_SIZE=104857600  # 100MB in bytes
ALLOWED_EXTENSIONS="pdf,docx,xlsx,csv,txt,png,jpg,jpeg"

# AWS S3 (if using S3)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_REGION="us-east-1"

# Azure Blob (if using Azure)
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_CONTAINER_NAME=""

# ============================================================
# Email/SMTP Configuration
# ============================================================
SMTP_ENABLED=true
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="your-email@example.com"
SMTP_PASSWORD="your-email-password"
SMTP_USE_TLS=true
SMTP_FROM_EMAIL="noreply@sicogrc.com"
SMTP_FROM_NAME="SICO GRC Platform"

# ============================================================
# Background Tasks (Celery)
# ============================================================
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"
CELERY_TASK_SERIALIZER="json"
CELERY_ACCEPT_CONTENT="json"
CELERY_TIMEZONE="Asia/Riyadh"

# ============================================================
# External Integrations
# ============================================================
# SIEM Integration
SIEM_ENABLED=false
SIEM_TYPE="splunk"  # splunk, qradar, sentinel
SIEM_HOST=""
SIEM_PORT=""
SIEM_API_KEY=""

# Active Directory / LDAP
LDAP_ENABLED=false
LDAP_SERVER=""
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_BASE_DN=""
LDAP_BIND_DN=""
LDAP_BIND_PASSWORD=""

# ============================================================
# Monitoring & Logging
# ============================================================
# Sentry (Error Tracking)
SENTRY_ENABLED=false
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE=0.1

# Application Insights
APP_INSIGHTS_ENABLED=false
APP_INSIGHTS_KEY=""

# ============================================================
# Feature Flags
# ============================================================
FEATURE_AI_ASSISTANT=true
FEATURE_SOC_BRIDGE=true
FEATURE_REPORTING=true
FEATURE_MOBILE_APP=false
FEATURE_MULTI_TENANT=false

# ============================================================
# Regulatory Framework Versions
# ============================================================
ECC_VERSION="2.0"
CCC_VERSION="1.0"
PDPL_EFFECTIVE_DATE="2023-09-14"

# ============================================================
# Localization
# ============================================================
DEFAULT_LANGUAGE="en"  # en, ar
SUPPORTED_LANGUAGES="en,ar"
DEFAULT_TIMEZONE="Asia/Riyadh"

# ============================================================
# Rate Limiting
# ============================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================================
# Development Tools
# ============================================================
# API Documentation
DOCS_ENABLED=true
DOCS_URL="/docs"
REDOC_URL="/redoc"

# Debug Toolbar
DEBUG_TOOLBAR=true

# Hot Reload
HOT_RELOAD=true
