# SICO GRC Platform - Environment Configuration

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sico_grc
DB_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=your-secret-key-change-this
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=SICO GRC Platform

# Vector Database (Chroma/Weaviate)
VECTOR_DB_TYPE=chroma
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=8001
VECTOR_DB_COLLECTION=sico_knowledge

# AI/NLP
OPENAI_API_KEY=your-openai-api-key
EMBEDDINGS_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.1

# Language Settings
DEFAULT_LANGUAGE=ar
SUPPORTED_LANGUAGES=ar,en

# Security
JWT_SECRET=your-jwt-secret-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# Compliance
ECC_VERSION=3.0
CCC_VERSION=1.0
PDPL_VERSION=2023
