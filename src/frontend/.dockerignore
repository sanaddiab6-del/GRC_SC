# =============================================================================
# Docker Ignore File - Frontend
# =============================================================================
# Excludes unnecessary files from Docker build context for:
# - Faster builds (smaller context upload)
# - Improved security (no sensitive files)
# - Smaller final image size
# =============================================================================

# Dependencies (will be installed via npm ci)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs (will be generated during build)
.next
out
dist
build

# Testing
coverage
.nyc_output
*.test.js
*.test.ts
*.test.tsx
*.spec.js
*.spec.ts
*.spec.tsx
__tests__
__mocks__

# Development files
.env*.local
.env.development
.env.test

# IDE and editor files
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# Git
.git
.gitignore
.gitattributes

# CI/CD
.github
.gitlab-ci.yml
.travis.yml

# Documentation
README.md
CHANGELOG.md
docs/
*.md

# Misc
.cache
.temp
tmp/
*.log
