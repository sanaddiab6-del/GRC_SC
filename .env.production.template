# ============================================================================
# SICO GRC Platform - Production Environment Configuration
# NCA ECC, NCA CCC, and PDPL Compliant Configuration
# ============================================================================

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME="SICO GRC Platform"
DEBUG=false
ENV=production
LOG_LEVEL=INFO

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL Required)
# ============================================================================
# Production: Use secure PostgreSQL instance
DATABASE_URL=postgresql+asyncpg://sico_user:CHANGE_THIS_PASSWORD@postgres:5432/sico_grc
DATABASE_URL_SYNC=postgresql://sico_user:CHANGE_THIS_PASSWORD@postgres:5432/sico_grc
DATABASE_ECHO=false

# ============================================================================
# REDIS CACHE
# ============================================================================
REDIS_URL=redis://redis:6379/0
CACHE_TTL=3600

# ============================================================================
# VECTOR DATABASE (AI/RAG)
# ============================================================================
VECTOR_DB_TYPE=chroma
VECTOR_DB_HOST=chroma
VECTOR_DB_PORT=8000

# ============================================================================
# SECURITY CONFIGURATION (NCA ECC-IS-3, PDPL Article 29)
# ============================================================================

# SECRET_KEY: REQUIRED - Minimum 32 characters
# Generate using: openssl rand -hex 32
# CRITICAL: Change this in production!
SECRET_KEY=CHANGE_THIS_TO_64_CHARACTER_RANDOM_STRING_IN_PRODUCTION_USE_OPENSSL_RAND

# ENCRYPTION_KEY: REQUIRED for PII encryption (PDPL Article 29)
# Generate using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CRITICAL: Store in Azure Key Vault in production!
ENCRYPTION_KEY=CHANGE_THIS_TO_FERNET_KEY_GENERATED_BY_CRYPTOGRAPHY_LIBRARY

# JWT Configuration
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# AZURE KEY VAULT (Production Secrets Management)
# ============================================================================
# Enable Azure Key Vault for secure secrets storage
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id

# ============================================================================
# RATE LIMITING (NCA ECC-IS-3 DDoS Protection)
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================================================
# TLS/HTTPS CONFIGURATION (NCA ECC-IS-3)
# ============================================================================
# REQUIRED in production per NCA ECC requirements
TLS_ENABLED=true
TLS_CERT_PATH=/etc/ssl/certs/server.crt
TLS_KEY_PATH=/etc/ssl/private/server.key

# ============================================================================
# AUDIT LOGGING (NCA ECC-IS-5, 7-Year Retention)
# ============================================================================
AUDIT_LOG_RETENTION_YEARS=7
AUDIT_LOG_STORAGE_PATH=/var/log/sico/audit

# ============================================================================
# AI/RAG CONFIGURATION
# ============================================================================
# Embedding model for bilingual RAG (Arabic + English)
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# LLM model (use local model for air-gapped deployment)
LLM_MODEL=gpt-4

# RAG parameters
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=128

# ============================================================================
# REGULATORY APIS (Optional - for real-time compliance checks)
# ============================================================================
PDPL_API_URL=https://api.dga.gov.sa/pdpl
SAMA_API_URL=https://www.sama.gov.sa
CITC_API_URL=https://www.citc.gov.sa
NCA_API_URL=https://nca.gov.sa

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=https://your-frontend-domain.com,https://your-admin-domain.com

# ============================================================================
# MULTI-TENANCY
# ============================================================================
ENABLE_MULTI_TENANCY=true
DEFAULT_TENANT_ID=default

# ============================================================================
# DATA SOVEREIGNTY (Saudi Arabia)
# ============================================================================
# Ensure all data remains within Saudi Arabia
DATA_RESIDENCY=SA
ALLOWED_REGIONS=saudi-arabia
CLOUD_PROVIDER=on-premise

# ============================================================================
# BACKUP AND DISASTER RECOVERY
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # 2 AM daily
BACKUP_RETENTION_DAYS=90
BACKUP_LOCATION=/var/backups/sico

# ============================================================================
# ALERTS AND MONITORING
# ============================================================================
ENABLE_ALERTS=true
ALERT_EMAIL=security-team@your-organization.sa
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================================================
# COMPLIANCE REPORTING
# ============================================================================
COMPLIANCE_REPORT_SCHEDULE="0 0 1 * *"  # Monthly on 1st
REPORT_RECIPIENTS=compliance@your-organization.sa,ciso@your-organization.sa

# ============================================================================
# DEVELOPMENT/TESTING OVERRIDES (Remove in production!)
# ============================================================================
# CI=true
# PYTEST_RUNNING=1
