# SICO GRC Platform - Environment Configuration
# ⚠️ CRITICAL: Never commit this file to version control!

# ============================================================================
# APPLICATION
# ============================================================================
APP_NAME=SICO GRC Platform
DEBUG=False
LOG_LEVEL=INFO

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=sqlite+aiosqlite:///./sico_grc.db
DATABASE_URL_SYNC=sqlite:///./sico_grc.db
DATABASE_ECHO=False

# Production: Use PostgreSQL
# DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/sico_grc
# DATABASE_URL_SYNC=postgresql://username:password@localhost:5432/sico_grc

# ============================================================================
# SECURITY - NCA ECC-IS-3 & PDPL Article 29 COMPLIANCE
# ============================================================================

# JWT Secret Key (REQUIRED - Min 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS

# Field-level Encryption Key for PII (REQUIRED)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_THIS_TO_A_FERNET_KEY

# Token expiration
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# AZURE KEY VAULT (Production Only)
# ============================================================================
#AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/
#AZURE_CLIENT_ID=your-client-id
#AZURE_CLIENT_SECRET=your-client-secret
#AZURE_TENANT_ID=your-tenant-id

# ============================================================================
# TLS/HTTPS (Production)
# ============================================================================
TLS_ENABLED=True
TLS_CERT_PATH=/etc/ssl/certs/server.crt
TLS_KEY_PATH=/etc/ssl/private/server.key

# ============================================================================
# RATE LIMITING - Attack Prevention
# ============================================================================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================================================
# AUDIT LOGGING - NCA ECC-IS-5 (7-year retention)
# ============================================================================
AUDIT_LOG_RETENTION_YEARS=7
AUDIT_LOG_STORAGE_PATH=/var/log/sico/audit

# ============================================================================
# REDIS CACHE
# ============================================================================
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# ============================================================================
# CORS - Frontend Origins
# ============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-production-domain.com

# ============================================================================
# AI/RAG CONFIGURATION
# ============================================================================
EMBEDDING_MODEL=intfloat/multilingual-e5-large
LLM_MODEL=gpt-4
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=128

# OpenAI API Key (if using GPT models)
OPENAI_API_KEY=your-openai-api-key-here

# ============================================================================
# VECTOR DATABASE
# ============================================================================
VECTOR_DB_TYPE=chroma
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=8001

# ============================================================================
# EXTERNAL REGULATORY APIs
# ============================================================================
PDPL_API_URL=https://api.dga.gov.sa/pdpl
SAMA_API_URL=https://www.sama.gov.sa
CITC_API_URL=https://www.citc.gov.sa

# ============================================================================
# SUPPORTED FRAMEWORKS
# ============================================================================
SUPPORTED_FRAMEWORKS=ECC,CCC,PDPL
DEFAULT_LANGUAGE=ar
